{
  "manifest_version": 3,
  "name": "Browser Bridge",
  "version": "0.1.0",
  "description": "Let an MCP client (Claude Code, Codex, …) operate this real Chrome — your tabs, your login sessions. You approve new sites and high-risk actions.",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "nativeMessaging",
    "debugger",
    "cookies"
  ],
  "host_permissions": [],
  "optional_host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Browser Bridge"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
