{
  "manifest_version": 3,
  "name": "Browser Bridge",
  "version": "0.2.0",
  "description": "Let an MCP client (Claude Code, Codex, …) operate your real Chrome — your tabs and logins. You approve new sites and risky actions.",
  "key": "",
  "permissions": [
    "tabs",
    "tabGroups",
    "scripting",
    "storage",
    "nativeMessaging",
    "debugger",
    "cookies"
  ],
  "host_permissions": [],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Browser Bridge"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
